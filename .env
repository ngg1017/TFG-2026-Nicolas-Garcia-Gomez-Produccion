#Credenciales para la base de datos PostgreSQL de prueba en Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tfg_bbdd

#Conexion a la bbdd del exterior desde el contenedor docker
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/tfg_bbdd
#Para conectarse a otra maquina hay q usar su ip en la intranet
#DATABASE_URL=postgresql://postgres:postgres@192.168.1.45:5432/tfg_bbdd